{
  "name": "equipment-health-monitor-backend",
  "version": "2.0.0",
  "description": "AI-powered equipment health monitoring with authentication",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "create-admin": "node scripts/createAdmin.js",
    "test": "echo \"No tests specified\" && exit 0",
    "setup-ml": "npm run install-python && npm run train-model",
    "install-python": "cd python && pip3 install -r requirements.txt",
    "train-model": "cd python && python3 train_model.py"
  },
  "keywords": ["equipment", "monitoring", "AI", "ML", "authentication"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "axios": "^1.5.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-session": "^1.17.3",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6",
    "nodemailer": "^6.9.7",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.8.0"
  }
}